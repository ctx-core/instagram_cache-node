{
	"name": "@ctx-core/instagram_cache-node",
	"version": "0.2.445",
	"description": "instagram scraper, account cache, & gallery component",
	"keywords": [
		"ctx-core",
		"instagram",
		"cache",
		"nodejs"
	],
	"homepage": "https://github.com/ctx-core/instagram_cache-node#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/instagram_cache-node/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/instagram_cache-node.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-instagram_cache-node@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"bin",
		"created_time",
		"dynamodb",
		"medium_href_a",
		"s3__medium_pathname_a__put",
		"webdriver__scrape__cache__put"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"bin": {
		"cache-instagram": "./bin/cache-instagram.mjs"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit",
		"start": "./bin/instagram_cache.js"
	},
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.1002.0",
		"@aws-sdk/client-s3": "^3.1002.0",
		"@ctx-core/env": "*",
		"@ctx-core/instagram": "*",
		"@ctx-core/instagram_cache": "*",
		"ctx-core": "*",
		"jsdom": "^28.1.0",
		"selenium-webdriver": "^4.41.0"
	},
	"devDependencies": {
		"@aws-sdk/types": "^3.973.4",
		"@types/jsdom": "^28.0.0",
		"@types/selenium-webdriver": "^4.35.5",
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"sideEffects": false
}
